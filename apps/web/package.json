{
  "name": "read-translate-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:gh-pages": "tsc && cross-env BASE_PATH=/reader/ vite build",
    "preview": "vite preview",
    "preview:gh-pages": "cross-env BASE_PATH=/reader/ vite preview",
    "test": "vitest run",
    "test:translation-pipeline": "vitest run src/lib/translationPipeline.integration.test.ts",
    "test:watch": "vitest",
    "epub:feature-sample": "node scripts/build-reader-feature-epub.mjs"
  },
  "dependencies": {
    "compromise": "^14.14.4",
    "dompurify": "^3.2.4",
    "epubjs": "^0.3.93",
    "idb": "^8.0.2",
    "linkedom": "^0.18.12",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/dompurify": "^3.2.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^7.0.3",
    "jsdom": "^26.0.0",
    "jszip": "^3.10.1",
    "typescript": "~5.7.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^3.0.9"
  }
}
